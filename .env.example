# Copy this file to .env and fill in your key.

# Which AI provider to use: "gemini" (free tier) or "claude" (paid, best quality)
PROVIDER=gemini

# Free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional backup brain from a DIFFERENT company, so Ms Ilona keeps working
# even if all of Google is down. Free key from https://console.groq.com/keys
GROQ_API_KEY=

# --- Supabase (saves conversations + user login) ---
# All from your Supabase project: Settings -> API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Optional: override the Gemini model (default: gemini-flash-latest)
# GEMINI_MODEL=gemini-flash-latest

# Only needed when PROVIDER=claude (get one at https://platform.claude.com)
# Also run: npm install @anthropic-ai/sdk
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-opus-4-8
